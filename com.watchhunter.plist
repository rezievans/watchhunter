<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.watchhunter.agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>WATCHHUNTER_DIR/.venv/bin/python3</string>
        <string>WATCHHUNTER_DIR/main.py</string>
        <string>--config</string>
        <string>WATCHHUNTER_DIR/config.json</string>
    </array>

    <key>WorkingDirectory</key>
    <string>WATCHHUNTER_DIR</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>WATCHHUNTER_DIR/.venv/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>CAFFEINATE_CHILD</key>
        <string>1</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>HOME_DIR/Library/Logs/watchhunter.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>HOME_DIR/Library/Logs/watchhunter.stderr.log</string>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
